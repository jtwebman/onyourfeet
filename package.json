{
	"name": "onyourfeet",
	"description": "A no-frills stand-up reminder and desk break timer for office workers. Start a 30/45/60-minute work timer and get nudged to take a 5-minute walking break.",
	"private": true,
	"version": "1.0.0",
	"license": "AGPL-3.0-or-later",
	"homepage": "https://onyourfeet.app",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jtwebman/onyourfeet.git"
	},
	"keywords": [
		"stand-up-reminder",
		"desk-break-timer",
		"work-breaks",
		"sedentary-health",
		"sveltekit",
		"cloudflare-workers"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "wrangler types --check && npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.15.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wrangler": "^4.81.0"
	}
}
